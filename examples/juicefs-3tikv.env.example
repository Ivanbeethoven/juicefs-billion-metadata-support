# TiUP / TiKV
TIDB_VERSION=v8.5.6
TIDB_ARCH=amd64
CLUSTER_NAME=juicefs-tikv-3
TOPOLOGY=tiup/topology.3tikv.example.yaml
SSH_USER=root
SSH_KEY=/root/.ssh/id_rsa
PD_ENDPOINT=http://10.0.1.11:2379

# JuiceFS binary
JUICEFS_VERSION=1.3.1
JUICEFS_ARCH=amd64
JUICEFS_INSTALL_DIR=/usr/local/bin

# JuiceFS filesystem
JFS_NAME=juicefs-prod
META_URL=tikv://10.0.1.11:2379,10.0.1.12:2379,10.0.1.13:2379/juicefs-prod
JFS_STORAGE=s3
JFS_BUCKET=https://s3.example.internal/juicefs-prod
JFS_ACCESS_KEY=replace-with-access-key
JFS_SECRET_KEY=replace-with-secret-key
JFS_TRASH_DAYS=0

# Mount service
MOUNT_POINT=/mnt/juicefs-prod
CACHE_DIR=/var/lib/juicefs/cache
CACHE_SIZE=102400
SERVICE_NAME=juicefs-prod

# Metadata benchmark
JUICEFS_TEST_HOSTS="10.0.1.11 10.0.1.12 10.0.1.13 10.0.1.21"
TEST_PREFIX=mdtest
TARGET_FILES_PER_NODE=25000000
FILES_PER_DIR=100000
DEPTH=2
MDTEST_DIRS=
THREADS=256
WRITE_SIZE=1
